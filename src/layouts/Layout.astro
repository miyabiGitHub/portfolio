---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "AI × Web × Infrastructure Engineer | Portfolio",
  description = "ChatGPT・Claude等のLLMを活用したアプリ開発を得意とし、インフラからアプリ実装まで一貫して対応するエンジニアのポートフォリオ。AWS 4冠・情報処理安全確保支援士をはじめ上位資格を多数保有。",
  ogImage = "/og-image.png",
} = Astro.props;

const siteUrl = "portfolio-8j2.pages.dev";
const ogImageUrl = `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="エンジニア, AI開発, Web開発, AWS, Python, ChatGPT, Claude, LLM, ポートフォリオ, 情報処理安全確保支援士"
    />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="Tech Aurora Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800&family=Noto+Sans+JP:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Devicons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
