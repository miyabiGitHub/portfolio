---
const navLinks = [
  { href: "#about", label: "About" },
  { href: "#skills", label: "Skills" },
  { href: "#work", label: "Works" },
  { href: "#certifications", label: "資格" },
  { href: "#contact", label: "Contact" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="#hero"
        class="text-xl font-bold aurora-text tracking-tight hover:opacity-80 transition-opacity"
      >
        &lt;Portfolio /&gt;
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-gray-400 hover:text-white transition-colors duration-200 relative group"
            >
              {link.label}
              <span class="absolute -bottom-1 left-0 w-0 h-px bg-aurora-gradient group-hover:w-full transition-all duration-300" />
            </a>
          ))
        }
        <a
          href="https://crowdworks.jp/public/employees/5888875?ref=share_url_wkprofile"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2 text-sm font-medium text-white rounded-full transition-all duration-300 hover:scale-105"
          style="background: linear-gradient(135deg, #4F8EF7, #A855F7);"
        >
          お問い合わせ
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-gray-400 hover:text-white transition-colors"
        aria-label="メニューを開く"
      >
        <svg
          id="menu-icon"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-white/5 bg-dark-900/95 backdrop-blur-md"
  >
    <div class="px-4 py-4 space-y-2">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link block py-3 px-4 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://crowdworks.jp/public/employees/5888875?ref=share_url_wkprofile"
        target="_blank"
        rel="noopener noreferrer"
        class="block py-3 px-4 text-center text-white font-medium rounded-lg mt-2"
        style="background: linear-gradient(135deg, #4F8EF7, #A855F7);"
      >
        お問い合わせ
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  // Scroll effect
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar?.classList.add(
        "bg-dark-900/90",
        "backdrop-blur-md",
        "border-b",
        "border-white/5",
        "shadow-lg"
      );
    } else {
      navbar?.classList.remove(
        "bg-dark-900/90",
        "backdrop-blur-md",
        "border-b",
        "border-white/5",
        "shadow-lg"
      );
    }
  });

  // Mobile menu toggle
  mobileMenuBtn?.addEventListener("click", () => {
    const isHidden = mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden", !isHidden);
    closeIcon?.classList.toggle("hidden", isHidden);
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      menuIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    });
  });
</script>
